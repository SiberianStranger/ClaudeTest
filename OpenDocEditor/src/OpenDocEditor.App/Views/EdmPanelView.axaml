<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OpenDocEditor.App.ViewModels"
             x:Class="OpenDocEditor.App.Views.EdmPanelView"
             x:DataType="vm:DocumentEditorViewModel">

  <StackPanel Margin="12" Spacing="8">

    <TextBlock Text="СЭД / Электронный документооборот"
               FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>

    <!-- Регистрационный номер -->
    <StackPanel Spacing="4">
      <TextBlock Text="Регистрационный номер:" FontSize="11" Foreground="Gray"/>
      <TextBox Text="{Binding Document.Edm.RegistrationNumber}"
               IsReadOnly="True" Background="#F5F5F5" FontSize="12"/>
    </StackPanel>

    <!-- Дата регистрации -->
    <StackPanel Spacing="4">
      <TextBlock Text="Дата регистрации:" FontSize="11" Foreground="Gray"/>
      <TextBox Text="{Binding Document.Edm.RegistrationDate, StringFormat='{}{0:dd.MM.yyyy}', FallbackValue=''}"
               IsReadOnly="True" Background="#F5F5F5" FontSize="12"/>
    </StackPanel>

    <!-- Состояние маршрута -->
    <StackPanel Spacing="4">
      <TextBlock Text="Состояние:" FontSize="11" Foreground="Gray"/>
      <Border Padding="8,4" CornerRadius="4" Background="#E3F2FD">
        <TextBlock Text="{Binding Document.Edm.WorkflowState}"
                   FontSize="12" Foreground="#1565C0" FontWeight="Medium"/>
      </Border>
    </StackPanel>

    <!-- Степень конфиденциальности -->
    <StackPanel Spacing="4">
      <TextBlock Text="Гриф:" FontSize="11" Foreground="Gray"/>
      <ComboBox SelectedItem="{Binding Document.Edm.SecurityLevel}" HorizontalAlignment="Stretch">
        <ComboBoxItem>Public</ComboBoxItem>
        <ComboBoxItem>Confidential</ComboBoxItem>
        <ComboBoxItem>Secret</ComboBoxItem>
      </ComboBox>
    </StackPanel>

    <Separator Margin="0,8"/>

    <!-- Подписи ЭЦП -->
    <TextBlock Text="Электронные подписи:" FontSize="11" Foreground="Gray"/>
    <ItemsControl ItemsSource="{Binding Document.Edm.Signatures}">
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <Border Margin="0,2" Padding="8,6" CornerRadius="4" Background="#F1F8E9">
            <StackPanel Spacing="2">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <PathIcon Data="M12,1L3,5V11C3,16.55 6.84,21.74 12,23C17.16,21.74 21,16.55 21,11V5L12,1Z"
                          Width="12" Height="12" Foreground="#2E7D32"/>
                <TextBlock Text="{Binding SignerName}" FontSize="11" FontWeight="Medium"/>
              </StackPanel>
              <TextBlock Text="{Binding SignedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                         FontSize="10" Foreground="Gray"/>
              <TextBlock Text="{Binding Algorithm}" FontSize="10" Foreground="Gray"/>
            </StackPanel>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <Separator Margin="0,8"/>

    <!-- Журнал аудита -->
    <TextBlock Text="История действий:" FontSize="11" Foreground="Gray"/>
    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
      <ItemsControl ItemsSource="{Binding Document.Edm.AuditLog}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Margin="0,1" Padding="6,4">
              <Grid ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                           FontSize="10" Foreground="Gray" Width="40"/>
                <TextBlock Grid.Column="1" Text="{Binding Action}"
                           FontSize="10" TextWrapping="Wrap"/>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

  </StackPanel>
</UserControl>
