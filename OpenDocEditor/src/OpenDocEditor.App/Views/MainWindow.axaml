<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenDocEditor.App.ViewModels"
        xmlns:v="using:OpenDocEditor.App.Views"
        x:Class="OpenDocEditor.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding AppTitle}"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="540"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="Full"
        ExtendClientAreaToDecorationsHint="False"
        CanResize="True"
        Background="#EBEBEB">

  <Window.Styles>

    <!-- Toolbar button -->
    <Style Selector="Button.tb">
      <Setter Property="Width" Value="34"/>
      <Setter Property="Height" Value="34"/>
      <Setter Property="Padding" Value="5"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.tb:pointerover">
      <Setter Property="Background" Value="#EBF3FB"/>
      <Setter Property="BorderBrush" Value="#C8DDF0"/>
    </Style>
    <Style Selector="Button.tb:pressed">
      <Setter Property="Background" Value="#D6EAF8"/>
    </Style>
    <Style Selector="Button.tb.on">
      <Setter Property="Background" Value="#D0E8FF"/>
      <Setter Property="BorderBrush" Value="#0078D4"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- Toolbar separator -->
    <Style Selector="Separator.tsep">
      <Setter Property="Width" Value="1"/>
      <Setter Property="Height" Value="22"/>
      <Setter Property="Background" Value="#CCCCCC"/>
      <Setter Property="Margin" Value="5,0"/>
    </Style>

    <!-- Tab close button -->
    <Style Selector="Button.tabclose">
      <Setter Property="Width" Value="18"/>
      <Setter Property="Height" Value="18"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="CornerRadius" Value="3"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Foreground" Value="#666666"/>
    </Style>
    <Style Selector="Button.tabclose:pointerover">
      <Setter Property="Background" Value="#E0E0E0"/>
      <Setter Property="Foreground" Value="#333333"/>
    </Style>

  </Window.Styles>

  <DockPanel>

    <!-- ═══ MENU BAR ════════════════════════════════════════════════════════ -->
    <Menu DockPanel.Dock="Top" Background="#FFFFFF" Padding="4,2">
      <MenuItem Header="Файл" Padding="8,4">
        <MenuItem Header="Создать"          Command="{Binding NewDocumentCommand}"   InputGesture="Ctrl+N"/>
        <MenuItem Header="Открыть..."       x:Name="OpenMenuItem"                    InputGesture="Ctrl+O"/>
        <Separator/>
        <MenuItem Header="Сохранить"        Command="{Binding SaveDocumentCommand}"  InputGesture="Ctrl+S"/>
        <MenuItem Header="Сохранить как..."  x:Name="SaveAsMenuItem"                 InputGesture="Ctrl+Shift+S"/>
        <Separator/>
        <MenuItem Header="Экспорт в PDF..."  x:Name="ExportPdfMenuItem"              InputGesture="Ctrl+Shift+E"/>
        <Separator/>
        <MenuItem Header="Недавние файлы" ItemsSource="{Binding RecentFiles}">
          <MenuItem.ItemTemplate>
            <DataTemplate x:DataType="vm:RecentFile"><TextBlock Text="{Binding DisplayText}"/></DataTemplate>
          </MenuItem.ItemTemplate>
        </MenuItem>
        <Separator/>
        <MenuItem Header="Выход" x:Name="ExitMenuItem"/>
      </MenuItem>

      <MenuItem Header="Правка" Padding="8,4">
        <MenuItem Header="Отменить"  Command="{Binding ActiveDocument.UndoCommand, FallbackValue={x:Null}}"  InputGesture="Ctrl+Z"/>
        <MenuItem Header="Повторить" Command="{Binding ActiveDocument.RedoCommand, FallbackValue={x:Null}}"  InputGesture="Ctrl+Y"/>
        <Separator/>
        <MenuItem Header="Найти и заменить..." x:Name="FindReplaceMenuItem" InputGesture="Ctrl+H"/>
      </MenuItem>

      <MenuItem Header="Вставка" Padding="8,4">
        <MenuItem Header="Разрыв страницы" Command="{Binding ActiveDocument.InsertPageBreakCommand, FallbackValue={x:Null}}"/>
      </MenuItem>

      <MenuItem Header="Документ" Padding="8,4">
        <MenuItem Header="Свойства документа..." x:Name="DocPropsMenuItem"/>
        <Separator/>
        <MenuItem Header="Зарегистрировать в СЭД" Command="{Binding RegisterInEdmCommand}"/>
        <MenuItem Header="Подписать ЭЦП..."        Command="{Binding SignDocumentCommand}"/>
        <MenuItem Header="Проверить подписи..."    x:Name="VerifySignaturesMenuItem"/>
        <Separator/>
        <MenuItem Header="Метаданные СЭД"          Command="{Binding ToggleEdmPanelCommand}"/>
      </MenuItem>

      <MenuItem Header="Вид" Padding="8,4">
        <MenuItem Header="Панель СЭД" Command="{Binding ToggleEdmPanelCommand}"/>
      </MenuItem>

      <MenuItem Header="Справка" Padding="8,4">
        <MenuItem Header="О программе..." x:Name="AboutMenuItem"/>
      </MenuItem>
    </Menu>

    <!-- ═══ TOOLBAR ═════════════════════════════════════════════════════════ -->
    <Border DockPanel.Dock="Top" Background="#FFFFFF"
            BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
            Padding="6,3">
      <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

        <!-- File ops -->
        <Button Classes="tb" ToolTip.Tip="Создать (Ctrl+N)" Command="{Binding NewDocumentCommand}">
          <PathIcon Data="M14,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H18A2,2 0 0,0 20,20V8L14,2M18,20H6V4H13V9H18V20Z" Width="16" Height="16" Foreground="#444"/>
        </Button>
        <Button Classes="tb" ToolTip.Tip="Открыть (Ctrl+O)" x:Name="OpenBtn">
          <PathIcon Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z" Width="16" Height="16" Foreground="#444"/>
        </Button>
        <Button Classes="tb" ToolTip.Tip="Сохранить (Ctrl+S)" Command="{Binding SaveDocumentCommand}">
          <PathIcon Data="M15,9H5V5H15M12,19A3,3 0 0,1 9,16A3,3 0 0,1 12,13A3,3 0 0,1 15,16A3,3 0 0,1 12,19M17,3H5C3.89,3 3,3.9 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V7L17,3Z" Width="16" Height="16" Foreground="#444"/>
        </Button>

        <Separator Classes="tsep"/>

        <!-- Undo/Redo -->
        <Button Classes="tb" ToolTip.Tip="Отменить (Ctrl+Z)" Command="{Binding ActiveDocument.UndoCommand, FallbackValue={x:Null}}">
          <PathIcon Data="M12.5,8C9.85,8 7.45,9 5.6,10.6L2,7V16H11L7.38,12.38C8.77,11.22 10.54,10.5 12.5,10.5C16.04,10.5 19.05,12.81 20.1,16L22.47,15.22C21.08,11.03 17.15,8 12.5,8Z" Width="16" Height="16" Foreground="#444"/>
        </Button>
        <Button Classes="tb" ToolTip.Tip="Повторить (Ctrl+Y)" Command="{Binding ActiveDocument.RedoCommand, FallbackValue={x:Null}}">
          <PathIcon Data="M18.4,10.6C16.55,9 14.15,8 11.5,8C6.85,8 2.92,11.03 1.54,15.22L3.9,16C4.95,12.81 7.95,10.5 11.5,10.5C13.45,10.5 15.23,11.22 16.62,12.38L13,16H22V7L18.4,10.6Z" Width="16" Height="16" Foreground="#444"/>
        </Button>

        <Separator Classes="tsep"/>

        <!-- Font name -->
        <ComboBox Width="160" Height="30" Margin="2,0"
                  ItemsSource="{Binding AvailableFonts}"
                  SelectedItem="{Binding ActiveDocument.CurrentFontName, FallbackValue='Times New Roman', Mode=TwoWay}"
                  ToolTip.Tip="Шрифт"/>

        <!-- Font size (editable combo) -->
        <ComboBox Width="58" Height="30" Margin="2,0"
                  ItemsSource="{Binding FontSizes}"
                  SelectedItem="{Binding ActiveDocument.CurrentFontSize, FallbackValue=12, Mode=TwoWay}"
                  ToolTip.Tip="Размер шрифта"/>

        <Separator Classes="tsep"/>

        <!-- Formatting -->
        <Button Classes="tb" ToolTip.Tip="Жирный (Ctrl+B)" Command="{Binding ActiveDocument.ToggleBoldCommand, FallbackValue={x:Null}}">
          <TextBlock Text="Ж" FontWeight="Bold" FontSize="14" Foreground="#333" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Button>
        <Button Classes="tb" ToolTip.Tip="Курсив (Ctrl+I)" Command="{Binding ActiveDocument.ToggleItalicCommand, FallbackValue={x:Null}}">
          <TextBlock Text="К" FontStyle="Italic" FontSize="14" Foreground="#333" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Button>
        <Button Classes="tb" ToolTip.Tip="Подчёркнутый (Ctrl+U)" Command="{Binding ActiveDocument.ToggleUnderlineCommand, FallbackValue={x:Null}}">
          <TextBlock Text="Ч" TextDecorations="Underline" FontSize="14" Foreground="#333" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Button>
        <Button Classes="tb" ToolTip.Tip="Зачёркнутый" Command="{Binding ActiveDocument.ToggleStrikethroughCommand, FallbackValue={x:Null}}">
          <TextBlock Text="З" TextDecorations="Strikethrough" FontSize="14" Foreground="#333" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Button>

        <Separator Classes="tsep"/>

        <!-- Alignment -->
        <Button Classes="tb" ToolTip.Tip="По левому краю" Command="{Binding ActiveDocument.SetAlignmentCommand, FallbackValue={x:Null}}" CommandParameter="Left">
          <PathIcon Data="M3,3H21V5H3V3M3,7H15V9H3V7M3,11H21V13H3V11M3,15H15V17H3V15M3,19H21V21H3V19Z" Width="16" Height="16" Foreground="#444"/>
        </Button>
        <Button Classes="tb" ToolTip.Tip="По центру" Command="{Binding ActiveDocument.SetAlignmentCommand, FallbackValue={x:Null}}" CommandParameter="Center">
          <PathIcon Data="M3,3H21V5H3V3M7,7H17V9H7V7M3,11H21V13H3V11M7,15H17V17H7V15M3,19H21V21H3V19Z" Width="16" Height="16" Foreground="#444"/>
        </Button>
        <Button Classes="tb" ToolTip.Tip="По правому краю" Command="{Binding ActiveDocument.SetAlignmentCommand, FallbackValue={x:Null}}" CommandParameter="Right">
          <PathIcon Data="M3,3H21V5H3V3M9,7H21V9H9V7M3,11H21V13H3V11M9,15H21V17H9V15M3,19H21V21H3V19Z" Width="16" Height="16" Foreground="#444"/>
        </Button>
        <Button Classes="tb" ToolTip.Tip="По ширине" Command="{Binding ActiveDocument.SetAlignmentCommand, FallbackValue={x:Null}}" CommandParameter="Justify">
          <PathIcon Data="M3,3H21V5H3V3M3,7H21V9H3V7M3,11H21V13H3V11M3,15H21V17H3V15M3,19H21V21H3V19Z" Width="16" Height="16" Foreground="#444"/>
        </Button>

        <Separator Classes="tsep"/>

        <!-- EDM / Signature -->
        <Button Classes="tb" ToolTip.Tip="Подписать ЭЦП" Command="{Binding SignDocumentCommand}">
          <PathIcon Data="M19.75,9.25L17.25,6.75L7.75,16.25L6.25,14.75L3.5,17.5L6,20L8.5,17.5L7,16L7.75,15.25L9.25,16.75L19.75,9.25Z M21,7L17,3L15,5L19,9L21,7Z" Width="16" Height="16" Foreground="#1565C0"/>
        </Button>
        <Button Classes="tb" ToolTip.Tip="Зарегистрировать в СЭД" Command="{Binding RegisterInEdmCommand}">
          <PathIcon Data="M14,10H19.5L14,4.5V10M5,3H15L21,9V19A2,2 0 0,1 19,21H5C3.89,21 3,20.1 3,19V5C3,3.89 3.89,3 5,3M5,12V14H19V12H5M5,16V18H14V16H5Z" Width="16" Height="16" Foreground="#2E7D32"/>
        </Button>

      </WrapPanel>
    </Border>

    <!-- ═══ STATUS BAR ═══════════════════════════════════════════════════════ -->
    <Border DockPanel.Dock="Bottom" Background="#0078D4" Padding="10,4">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto">
        <TextBlock Grid.Column="0" Text="{Binding StatusText}" Foreground="White" VerticalAlignment="Center" FontSize="12"/>
        <TextBlock Grid.Column="1" Margin="16,0" Foreground="#C8E6FF" VerticalAlignment="Center" FontSize="12"
                   Text="{Binding ActiveDocument.WordCount, StringFormat='Слов: {0}', FallbackValue='Слов: 0'}"/>
        <TextBlock Grid.Column="2" Margin="8,0" Foreground="#90CAF9" VerticalAlignment="Center" FontSize="12"
                   Text="{Binding ActiveDocument.Document.Edm.WorkflowState, FallbackValue=''}"/>
        <ProgressBar Grid.Column="3" Width="100" Height="5" Margin="8,0" IsIndeterminate="True"
                     IsVisible="{Binding IsBusy}" Foreground="White" Background="#0060B0"/>
      </Grid>
    </Border>

    <!-- ═══ MAIN CONTENT ════════════════════════════════════════════════════ -->
    <Grid ColumnDefinitions="*,Auto">

      <TabControl Grid.Column="0"
                  ItemsSource="{Binding OpenDocuments}"
                  SelectedItem="{Binding ActiveDocument}">
        <TabControl.ItemTemplate>
          <DataTemplate x:DataType="vm:DocumentEditorViewModel">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="{Binding Title}" VerticalAlignment="Center" MaxWidth="180" TextTrimming="CharacterEllipsis" FontSize="13"/>
              <Button Classes="tabclose" Content="✕"/>
            </StackPanel>
          </DataTemplate>
        </TabControl.ItemTemplate>
        <TabControl.ContentTemplate>
          <DataTemplate x:DataType="vm:DocumentEditorViewModel">
            <v:DocumentEditorView DataContext="{Binding}"/>
          </DataTemplate>
        </TabControl.ContentTemplate>
      </TabControl>

      <!-- EDM Panel -->
      <Border Grid.Column="1" Width="290" Background="#FAFAFA"
              BorderBrush="#DDDDDD" BorderThickness="1,0,0,0"
              IsVisible="{Binding IsEdmPanelVisible}">
        <v:EdmPanelView DataContext="{Binding ActiveDocument}"/>
      </Border>

    </Grid>
  </DockPanel>
</Window>
